                    <mxGeometry x="410" y="-70" width="80" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="40" value="Anything encrypted with Private Key  → can ONLY be decrypted by Public Key&lt;br/&gt;Anything encrypted with Public Key   → can ONLY be decrypted by Private Key" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
                    <mxGeometry x="212.5" y="-390" width="490" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="45" value="a person also modify/temper the document and calculate new hash signature of that document and then add that new hash in that document.&lt;div&gt;&lt;font color=&quot;#ffffff&quot;&gt;&lt;br&gt;&lt;/font&gt;This where the concept of public and private key comes in, now we have even encrypt the hash of the document also using private key, then that hash can only decrypted using public key, and if the hash is decrypt successfully, this will prove that the hash is not modified(incase if the encrypted hash is modified then the public key won,t be able to decrypt the encrypted hash, thus proving the temperness in the encrypted hash), and now once we have the authentic hash,&amp;nbsp; we also correctly verify document hash with this decrypted hash&amp;nbsp;&lt;span style=&quot;font-family: Poppins, &amp;quot;Noto Color Emoji&amp;quot;, sans-serif; font-size: 14px; text-align: start; white-space-collapse: preserve;&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(66, 66, 66), rgb(255, 255, 255));&quot;&gt;after independently calculating the hash of the document also&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;gradientColor=#ffd966;strokeColor=#d6b656;" vertex="1" parent="1">
                    <mxGeometry x="690" y="-90" width="550" height="180" as="geometry"/>
                </mxCell>
